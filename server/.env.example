# ──────────────────────────────────────────
# Ayuda Hannah – Server environment variables
# Copy this file to .env and fill in values
# NEVER commit .env to the repository
# ──────────────────────────────────────────

# ── ePayco ──
# Your ePayco merchant P_CUST_ID_CLIENTE (numeric customer id)
EPAYCO_CUSTOMER_ID=

# Your ePayco P_KEY (private key / secret key)
EPAYCO_P_KEY=

# ── Webhook security ──
# Shared secret used to validate incoming webhook requests.
# Generate a strong random string (e.g.: openssl rand -hex 32)
WEBHOOK_SECRET=

# ── GitHub API ──
# Personal Access Token with "repo" scope (or a GitHub App token).
# Used to commit updated data/donations.json and data/summary.json.
GITHUB_PAT=

# GitHub repository owner (your username or org name)
GITHUB_OWNER=luis2397

# GitHub repository name
GITHUB_REPO=ayudahannah

# Branch to commit changes to
GITHUB_BRANCH=main

# ── Admin ──
# Token required to access the /admin/* endpoints.
# Generate a strong random string (e.g.: openssl rand -hex 32)
ADMIN_TOKEN=

# ── Server ──
# Port the Express server listens on (default: 3000)
PORT=3000

# Campaign goal in COP
CAMPAIGN_GOAL=3000000
